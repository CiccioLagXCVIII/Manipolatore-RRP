<launch>

    <!-- AA ========== Configurazione Modello URDF Del Robot ========== -->

    <!-- BB Caricamento Dei Parametri Dal File YAML All'Avvio Del Sistema -->
    <rosparam command="load" file="$(find manipolatoreRRP)/config/robotParameters.yaml" />

    <!-- BB Definizione File XACRO (Valore Predefinito: Posizione File Nella Cartella URDF) -->
    <arg name="model" default="$(find manipolatoreRRP)/urdf/manipolatoreRRP.urdf.xacro"/>

    <!-- BB Generazione Descrizione Robot Convertendo Modello XACRO In URDF E Caricamento Nel Parametro Globale -->
    <param name="robot_description" command="$(find xacro)/xacro $(arg model)" />

    <!-- AA ========== Gestione Nodi Per Pubblicazione Dello Stato Dei Giunti ========== -->

    <!-- BB Definizione Argomento Per L'Abilitazione Dell' Interfaccia Grafica -->
    <arg name="gui" default="True" />

    <!-- BB Avvio Publisher Con Interfaccia Grafica Solo Se L'Argomento È Vero -->
    <node name="jointStatePublisherGui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" if="$(arg gui)"/>

    <!-- BB Avvio Publisher Standard Se L'Argomento GUI E Falso -->
    <!-- <node name="jointStatePublisher" pkg="joint_state_publisher" type="joint_state_publisher" unless="$(arg gui)" /> -->
    
    <!-- BB Calcola Le Trasformazioni TF Di Tutti I Link Usando I Dati Di Joint State -->
    <node name="robotStatePublisher" pkg="robot_state_publisher" type="robot_state_publisher" />
    
    <!-- AA ========== Avvio RViz Con File Di Configurazione Salvato ========== -->
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find manipolatoreRRP)/rviz/manipolatoreRRP.rviz" required="true">
        <!-- BB Disabilita Pop-up Di Avviso EOL Di ROS 1 -->
        <env name="DISABLE_ROS1_EOL_WARNINGS" value="1"/>
    </node>

    <!-- AA ========== Gestione Script ========== -->

    <!-- BB Script Per Il Movimento Del Manipolatore RRP Eseguito Solo Se La GUI È Disabilitata -->
    <node name="jointController" pkg="manipolatoreRRP" type="jointController.py" output="screen" unless="$(arg gui)" />

    <!-- BB  Script Che Stampa Le Matrici Di Trasformazione Omogenea -->
    <node name="tfPrinter" pkg="manipolatoreRRP" type="tfPrinter.py" output="screen" if="$(arg gui)"/>

</launch>